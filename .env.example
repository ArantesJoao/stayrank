# Copy to .env and fill in.

# Neon Postgres connection string (Connection pooling OFF / direct connection).
# Neon dashboard → Connect → copy the string.
# Use sslmode=verify-full (Neon has valid CA certs) — avoids the pg SSL warning.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/stayrank?sslmode=verify-full"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth credentials (GCP → APIs & Services → Credentials → OAuth client ID, Web)
# Authorized redirect URI (local):  http://localhost:3737/api/auth/callback/google
# Authorized redirect URI (prod):   https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
